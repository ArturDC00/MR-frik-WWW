# Skopiuj do .env.local (nie commituj .env.local).
# Next ładuje zmienne przy `next build` — po zmianie URL / HSTS zrób ponownie build na serwerze.

# Kanoniczna domena strony (metadata, sitemap w runtime przez public/ — patrz layout).
NEXT_PUBLIC_SITE_URL=https://mrfrik.com
# Strict-Transport-Security w next.config — WŁĄCZ tylko gdy strona działa wyłącznie pod HTTPS.
# ENABLE_HSTS=true

# Bitrix24 — inbound webhook (crm.lead.add). Ustaw w .env.local na serwerze; NIE commituj tokenu.
# Kształt (TYLKO baza, bez crm.lead.add na końcu): https://<portal>.bitrix24.pl/rest/<USER_ID>/<TOKEN>/
# Formularz woła POST /api/lead; serwer dopina crm.lead.add.json (patrz src/app/api/lead/route.js).
# BITRIX24_WEBHOOK_BASE=

# Opcjonalnie: sól do hasha IP w /api/import-count (domyślna wbudowana). Zmień przy deployu produkcyjnym.
# IMPORT_COUNTER_SALT=
